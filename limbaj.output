Terminals unused in grammar

    BOOL_VAL


Grammar

    0 $accept: progr $end

    1 $@1: ε

    2 $@2: ε

    3 progr: $@1 global_definitions $@2 main_block

    4 global_definitions: ε
    5                   | global_definitions global_decl_var
    6                   | global_definitions class_def
    7                   | global_definitions func_def

    8 global_decl_var: TYPE vars ';'
    9                | ID ID ';'
   10                | TYPE ID ASSIGN NR_INT ';'
   11                | TYPE ID ASSIGN NR_FLOAT ';'
   12                | TYPE ID ASSIGN STRING_VAL ';'
   13                | TYPE ID ASSIGN TRUE ';'
   14                | TYPE ID ASSIGN FALSE ';'

   15 vars: ID
   16     | vars ',' ID

   17 $@3: ε

   18 class_def: CLASS ID $@3 BGIN class_body END

   19 class_body: ε
   20           | class_body access_modifier class_members

   21 access_modifier: PUBLIC
   22                | PRIVATE
   23                | PROTECTED

   24 class_members: class_member_list

   25 class_member_list: ε
   26                  | class_member_list class_member

   27 class_member: class_field
   28             | class_method
   29             | constructor_def

   30 constructor_def: FUNCTION ID '(' ')' BGIN func_block END

   31 class_field: TYPE vars ';'
   32            | ID ID ';'

   33 $@4: ε

   34 class_method: FUNCTION TYPE func_name '(' list_param ')' $@4 BGIN func_block END

   35 $@5: ε

   36 func_def: FUNCTION TYPE func_name '(' list_param ')' $@5 BGIN func_block END

   37 $@6: ε

   38 func_def: FUNCTION ID func_name '(' list_param ')' $@6 BGIN func_block END

   39 func_name: ID

   40 func_block: ε
   41           | func_block func_item

   42 func_item: TYPE ID ';'
   43          | TYPE ID ASSIGN ast_expr ';'
   44          | control_stmt
   45          | id_start_item ';'
   46          | RETURN expr ';'
   47          | RETURN expr_bool ';'

   48 id_start_item: ID ID
   49              | ID ID ASSIGN expr_bool
   50              | ID ASSIGN expr_bool
   51              | ID ASSIGN NEW ID '(' ')'
   52              | ID '.' ID ASSIGN expr_bool
   53              | ID '(' call_list ')'
   54              | ID '.' ID '(' call_list ')'
   55              | PRINT '(' expr ')'

   56 list_param: ε
   57           | param_list

   58 param_list: param
   59           | param_list ',' param

   60 param: TYPE ID
   61      | ID ID

   62 $@7: ε

   63 main_block: BGIN $@7 stmt_list_ast END

   64 simple_stmt: ID ASSIGN expr_bool
   65            | ID ASSIGN NEW ID '(' ')'
   66            | ID '.' ID ASSIGN expr
   67            | RETURN expr
   68            | RETURN expr_bool
   69            | PRINT '(' expr ')'
   70            | ID '(' call_list ')'

   71 control_stmt: IF '(' expr_bool ')' block_stmts
   72             | IF '(' expr_bool ')' block_stmts ELSE block_stmts
   73             | WHILE '(' expr_bool ')' block_stmts
   74             | FOR '(' simple_stmt ';' expr_bool ';' simple_stmt ')' block_stmts

   75 expr: '-' expr
   76     | expr '+' expr
   77     | expr '-' expr
   78     | expr '*' expr
   79     | expr '/' expr
   80     | expr '%' expr
   81     | '(' expr ')'
   82     | NR_INT
   83     | NR_FLOAT
   84     | STRING_VAL
   85     | ID
   86     | ID '.' ID
   87     | ID '.' ID '(' call_list ')'
   88     | ID '(' call_list ')'

   89 expr_bool: TRUE
   90          | FALSE
   91          | expr comp expr
   92          | expr_bool AND expr_bool
   93          | expr_bool OR expr_bool
   94          | NOT expr_bool
   95          | '(' expr_bool ')'

   96 stmt_list_ast: ε
   97              | stmt_list_ast statement_ast

   98 statement_ast: ast_simple_stmt ';'
   99              | control_stmt
  100              | TYPE ID ASSIGN ast_expr ';'
  101              | TYPE vars ';'

  102 ast_simple_stmt: ID ASSIGN NEW ID '(' ')'
  103                | ID ASSIGN ast_expr
  104                | ID '.' ID ASSIGN ast_expr
  105                | PRINT '(' ast_expr ')'
  106                | RETURN ast_expr

  107 ast_expr: NR_INT
  108         | NR_FLOAT
  109         | STRING_VAL
  110         | TRUE
  111         | FALSE
  112         | ast_expr GT ast_expr
  113         | ast_expr LT ast_expr
  114         | ast_expr EQ ast_expr
  115         | ast_expr NEQ ast_expr
  116         | ast_expr GE ast_expr
  117         | ast_expr LE ast_expr
  118         | ID
  119         | ID '.' ID '(' call_list_ast ')'
  120         | ID '(' call_list_ast ')'
  121         | ID '.' ID
  122         | ast_expr '+' ast_expr
  123         | ast_expr '-' ast_expr
  124         | ast_expr '*' ast_expr
  125         | ast_expr '/' ast_expr
  126         | ast_expr '%' ast_expr
  127         | '(' ast_expr ')'
  128         | ast_expr AND ast_expr
  129         | ast_expr OR ast_expr
  130         | NOT ast_expr

  131 comp: EQ
  132     | LE
  133     | GE
  134     | GT
  135     | LT
  136     | NEQ

  137 call_list: ε
  138          | expr
  139          | call_list ',' expr

  140 call_list_ast: ε
  141              | ast_expr
  142              | call_list_ast ',' ast_expr

  143 block_stmts: BGIN stmt_list_ast END


